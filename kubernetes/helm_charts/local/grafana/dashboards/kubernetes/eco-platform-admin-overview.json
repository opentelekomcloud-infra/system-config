          "limit": 100,
          "matchAny": false,
          "tags": [],
          "type": "dashboard"
        },
        "type": "dashboard"
      }
    ]
  },
  "description": "Cluster overview for platform admins - resource usage, pod health, node status, and recent errors with drill-down capability",
