      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "(sum(node_memory_MemTotal_bytes{cluster=\"$cluster\", job=~\"$job\"} - node_memory_MemAvailable_bytes{cluster=\"$cluster\", job=~\"$job\"}) / sum(node_memory_MemTotal_bytes{cluster=\"$cluster\", job=~\"$job\"})) * 100",
          "legendFormat": "Cluster Memory",
          "range": true,
          "refId": "A"
        }
      ],
