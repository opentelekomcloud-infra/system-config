# This file is kept updated by ansible, adapted from
# https://help.ubuntu.com/lts/serverguide/configuration.html

deb http://de.archive.ubuntu.com/ubuntu jammy main universe
deb http://de.archive.ubuntu.com/ubuntu jammy-updates main universe
deb http://de.archive.ubuntu.com/ubuntu jammy-backports main universe
deb http://de.archive.ubuntu.com/ubuntu jammy-security main universe
deb [arch=amd64 signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/ubuntu   jammy stable